{
  "__inputs": [],
  "__requires": [{ "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" }],
  "title": "Platform API Overview",
  "uid": "platform-api-overview",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{
        "expr": "sum(rate(http_server_requests_seconds_count{job=\"platform-api\"}[1m])) by (uri, method)",
        "legendFormat": "{{method}} {{uri}}"
      }]
    },
    {
      "id": 2,
      "title": "Error Rate (5xx %)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{
        "expr": "sum(rate(http_server_requests_seconds_count{job=\"platform-api\",status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=\"platform-api\"}[5m])) * 100",
        "legendFormat": "5xx %"
      }]
    },
    {
      "id": 3,
      "title": "p99 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"platform-api\"}[5m])) by (le, uri)) * 1000",
        "legendFormat": "p99 {{uri}}"
      }]
    },
    {
      "id": 4,
      "title": "Rate Limit Rejections (429/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [{
        "expr": "sum(rate(http_server_requests_seconds_count{job=\"platform-api\",status=\"429\"}[1m]))",
        "legendFormat": "429/s"
      }]
    }
  ]
}
