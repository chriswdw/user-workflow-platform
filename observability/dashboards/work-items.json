{
  "__inputs": [],
  "__requires": [{ "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" }],
  "title": "Work Items",
  "uid": "platform-work-items",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Ingestion Rate by Source",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{
        "expr": "sum(rate(platform_work_items_ingested_total[1m])) by (source)",
        "legendFormat": "{{source}}"
      }]
    },
    {
      "id": 2,
      "title": "Routing Fallback Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{
        "expr": "sum(rate(platform_routing_fallback_total[5m])) by (workflow_type)",
        "legendFormat": "{{workflow_type}}"
      }]
    },
    {
      "id": 3,
      "title": "Workflow Transition Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{
        "expr": "sum(rate(platform_workflow_transitions_total[1m])) by (workflow_type, transition)",
        "legendFormat": "{{workflow_type}}/{{transition}}"
      }]
    },
    {
      "id": 4,
      "title": "SLA Breaches",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [{
        "expr": "sum(rate(platform_sla_breaches_total[5m])) by (workflow_type)",
        "legendFormat": "{{workflow_type}}"
      }]
    }
  ]
}
